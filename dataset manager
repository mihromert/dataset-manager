            self.btn_plan_clear, self.btn_plan_cancel, self.plan_table
        ]:
            w.setEnabled(on)
    def on_plan_cancel_selected(self):
        row = self.plan_table.currentRow()
        if row < 0 or row >= len(self.model.deletion_ops):
            QMessageBox.information(self, "Plan", "Select one order to cancel.")
            return

        op = self.model.deletion_ops[row]
        reply = QMessageBox.question(
            self, "Cancel order",
            "Cancel the selected order?\n\n"
            "The deletion plan will be recomputed."
        )
        if reply != QMessageBox.Yes:
            return

        del self.model.deletion_ops[row]
        self.model.rebuild_deletion_sets_from_ops()
        self.refresh_stats()

    def selected_indices(self) -> List[int]:
        return sorted({self.class_list.row(it) for it in self.class_list.selectedItems()})

    def refresh_class_list(self):
        self.class_list.clear()
        for i, name in self.model.get_classes():
            self.class_list.addItem(QListWidgetItem(f"{i}: {name}"))

    def refresh_stats(self):
        try:
            box_by_idx, single_by_idx, overlap_by_idx, total_boxes, total_files, warnings = self.model.compute_stats()
        except Exception as e:
            QMessageBox.critical(self, "Error", str(e))
            return

        self.lbl_files.setText(f"Label files: {total_files}")
        self.lbl_boxes.setText(f"Total boxes kept: {total_boxes}")
        self.lbl_delplan.setText(
            f"Deletion plan: {len(self.model.delete_rel_labels)} labels, {len(self.model.delete_rel_images)} images"
        )

        classes = self.model.get_classes()
        self.table.setRowCount(len(classes))
        for r, (idx, name) in enumerate(classes):
            self.table.setItem(r, 0, QTableWidgetItem(str(idx)))
            self.table.setItem(r, 1, QTableWidgetItem(name))
            self.table.setItem(r, 2, QTableWidgetItem(str(box_by_idx.get(idx, 0))))
            self.table.setItem(r, 3, QTableWidgetItem(str(single_by_idx.get(idx, 0))))
            self.table.setItem(r, 4, QTableWidgetItem(str(overlap_by_idx.get(idx, 0))))

        if warnings:
            show = warnings[:12]
            extra = len(warnings) - len(show)
            txt = "Warnings:\n" + "\n".join(f"- {w}" for w in show)
            if extra > 0:
                txt += f"\n... (+{extra} more)"
            self.lbl_warn.setText(txt)
        else:
            self.lbl_warn.setText("")

        self.refresh_deletion_plan_view()

    def refresh_deletion_plan_view(self):
        ops = self.model.deletion_ops
        self.plan_table.setRowCount(len(ops))

        # to resolve names for display
        classes = {idx: name for idx, name in self.model.get_classes()}

        def mode_pretty(m: str) -> str:
            return {
                "single": "Single-class",
                "overlap-any": "Overlap (any)",
                "overlap-specific": "Overlap (specific)",
                "any": "Any containing class",
            }.get(m, m)

        for r, op in enumerate(ops):
            cls_name = classes.get(op.class_index, f"#{op.class_index}")
            self.plan_table.setItem(r, 0, QTableWidgetItem(f"{op.class_index}: {cls_name}"))
            self.plan_table.setItem(r, 1, QTableWidgetItem(mode_pretty(op.mode)))
            self.plan_table.setItem(r, 2, QTableWidgetItem(str(op.n)))
            self.plan_table.setItem(r, 3, QTableWidgetItem("Labels+Images" if op.delete_images_too else "Labels only"))

            if op.mode == "overlap-specific" and op.overlap_with_index is not None:
                other_name = classes.get(op.overlap_with_index, f"#{op.overlap_with_index}")
                self.plan_table.setItem(r, 4, QTableWidgetItem(f"{op.overlap_with_index}: {other_name}"))
            else:
                self.plan_table.setItem(r, 4, QTableWidgetItem("-"))

    def on_plan_clear(self):
        self.model.clear_deletion_plan()
        self.refresh_stats()

    def on_plan_remove_selected(self):
        removed_labels = 0
        removed_images = 0

        # Remove selected labels
        for it in self.list_plan_labels.selectedItems():
            rel = it.text()
            if rel in self.model.delete_rel_labels:
                self.model.delete_rel_labels.remove(rel)
                removed_labels += 1

        # Remove selected images
        for it in self.list_plan_images.selectedItems():
            rel = it.text()
            if rel in self.model.delete_rel_images:
                self.model.delete_rel_images.remove(rel)
                removed_images += 1

        if removed_labels == 0 and removed_images == 0:
            QMessageBox.information(self, "Plan", "Nothing selected.")
            return

        self.refresh_stats()
        QMessageBox.information(self, "Plan", f"Removed: {removed_labels} labels, {removed_images} images")

    def on_select_input(self):
        folder = QFileDialog.getExistingDirectory(self, "Select INPUT YOLO dataset folder")
        if not folder:
            return
        try:
            self.model.load_input(folder)
            self.lbl_in.setText(f"Input: {os.path.abspath(folder)}")
            self.refresh_class_list()
            self.refresh_stats()
            self.set_enabled(True)
        except Exception as e:
            QMessageBox.critical(self, "Error", str(e))
            self.set_enabled(False)

    def on_select_output(self):
        folder = QFileDialog.getExistingDirectory(self, "Select OUTPUT folder (can be empty)")
        if not folder:
            return
        try:
            self.model.set_output(folder)
            self.lbl_out.setText(f"Output: {os.path.abspath(folder)}")
        except Exception as e:
            QMessageBox.critical(self, "Error", str(e))

    def on_export_pdf(self):

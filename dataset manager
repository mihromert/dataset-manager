CLASSES_FILENAME = "classes.txt"
COMMON_IMAGE_EXTS = [".jpg", ".jpeg", ".png", ".bmp", ".webp", ".tif", ".tiff"]


class DatasetError(Exception):
    pass


def is_label_file(path: str) -> bool:
    base = os.path.basename(path).lower()
    return base.endswith(".txt") and base != CLASSES_FILENAME


def iter_all_files(root: str) -> List[str]:
    out = []
    for dirpath, _, filenames in os.walk(root):
        for fn in filenames:
            out.append(os.path.join(dirpath, fn))
    return sorted(out)


def iter_label_files(root: str) -> List[str]:
    return [p for p in iter_all_files(root) if is_label_file(p)]


def read_classes_txt(path: str) -> List[str]:
    if not os.path.exists(path):
        raise DatasetError(f"Missing {CLASSES_FILENAME} at: {path}")
    with open(path, "r", encoding="utf-8") as f:
        lines = [ln.rstrip("\n") for ln in f.readlines()]
    classes = [c.strip() for c in lines if c.strip()]
    if not classes:
        raise DatasetError(f"{CLASSES_FILENAME} is empty (no classes).")
    return classes


def write_classes_txt(path: str, classes: List[str]) -> None:
    os.makedirs(os.path.dirname(path), exist_ok=True)
    with open(path, "w", encoding="utf-8") as f:
        for c in classes:
            f.write(c + "\n")


def parse_label_line(line: str) -> Optional[Tuple[int, float, float, float, float]]:
    parts = line.strip().split()
    if len(parts) < 5:
        return None
    try:
        return int(parts[0]), float(parts[1]), float(parts[2]), float(parts[3]), float(parts[4])
    except ValueError:
        return None


def format_label_line(cid: int, x: float, y: float, w: float, h: float) -> str:
    return f"{cid} {x:.6f} {y:.6f} {w:.6f} {h:.6f}"


def find_matching_image(input_root: str, rel_label_path: str) -> Optional[str]:
    rel_dir = os.path.dirname(rel_label_path)
    stem = os.path.splitext(os.path.basename(rel_label_path))[0].lower()

    abs_dir = os.path.join(input_root, rel_dir) if rel_dir else input_root
    if not os.path.isdir(abs_dir):
        return None

    try:
        for fn in os.listdir(abs_dir):
            base, ext = os.path.splitext(fn)
            if base.lower() == stem and ext.lower() in COMMON_IMAGE_EXTS:
                rel = os.path.join(rel_dir, fn) if rel_dir else fn
                return os.path.normpath(rel)
    except OSError:
        return None

    return None


class YoloDatasetModel:
    def candidates_for_op(self, op: 'DeletionOp') -> List[str]:
        target_uid = self.class_order[op.class_index]
        alive_uids = set(self.class_order)

        require_uid = None
        if op.mode == "overlap-specific" and op.overlap_with_index is not None:
            require_uid = self.class_order[op.overlap_with_index]

        candidates: List[str] = []
        for rel in self.rel_label_files:
            classset = self.label_to_classset.get(rel, set())

            alive_uids_in_image: Set[int] = set()
            for ocid in classset:
                if ocid not in self.original_index_to_uid:
                    continue
                ouid = self._resolve_uid(self.original_index_to_uid[ocid])
                if ouid in alive_uids:
                    alive_uids_in_image.add(ouid)

            if target_uid not in alive_uids_in_image:
                continue

            if op.mode == "single":
                if len(alive_uids_in_image) == 1:
                    candidates.append(rel)
            elif op.mode == "overlap-any":
                if len(alive_uids_in_image) > 1:
                    candidates.append(rel)
            elif op.mode == "overlap-specific":
                if require_uid is None:
                    continue
                if len(alive_uids_in_image) > 1 and require_uid in alive_uids_in_image:
                    candidates.append(rel)
            elif op.mode == "any":
                candidates.append(rel)

        candidates.sort()
        return candidates

    def rebuild_deletion_sets_from_ops(self) -> None:
        self.delete_rel_labels.clear()
        self.delete_rel_images.clear()

        for op in self.deletion_ops:
            candidates = self.candidates_for_op(op)
            candidates = [c for c in candidates if c not in self.delete_rel_labels]
            take = candidates[:op.n]

            for rel_label in take:
                self.delete_rel_labels.add(rel_label)
                if op.delete_images_too:
                    rel_img = self.label_to_image_rel.get(rel_label)
                    if rel_img:
                        self.delete_rel_images.add(os.path.normpath(rel_img))
    """
    - Reads INPUT dataset.
    - Holds class edits + deletion plan in-memory.
    - APPLY writes NEW labels/classes into OUTPUT (INPUT not modified).
    """

    def __init__(self):
        self.in_root: Optional[str] = None
        self.out_root: Optional[str] = None

        self.original_classes: List[str] = []
        self.original_index_to_uid: Dict[int, int] = {}
        self.uid_to_name: Dict[int, str] = {}
        self.class_order: List[int] = []
        self.uid_redirect: Dict[int, int] = {}
        self.next_uid: int = 1
        self.loaded: bool = False

        # Index from input
        self.rel_label_files: List[str] = []
        self.label_to_classset: Dict[str, Set[int]] = {}
        self.label_to_box_counts: Dict[str, Dict[int, int]] = {}
        self.label_to_image_rel: Dict[str, Optional[str]] = {}

        # Deletion plan (affects OUTPUT only)
        self.delete_rel_labels: Set[str] = set()
        self.delete_rel_images: Set[str] = set()
        self.deletion_ops: List[DeletionOp] = []

    def load_input(self, dataset_root: str) -> None:
        dataset_root = os.path.abspath(dataset_root)
        classes = read_classes_txt(os.path.join(dataset_root, CLASSES_FILENAME))

        self.in_root = dataset_root
        self.original_classes = classes

        self.original_index_to_uid.clear()
        self.uid_to_name.clear()
        self.class_order.clear()
        self.uid_redirect.clear()
        self.next_uid = 1

        for i, name in enumerate(classes):
            uid = self.next_uid
            self.next_uid += 1
            self.original_index_to_uid[i] = uid
            self.uid_to_name[uid] = name
            self.class_order.append(uid)

        self._build_input_index()
        self.delete_rel_labels.clear()
        self.delete_rel_images.clear()
        self.loaded = True

    def _build_input_index(self) -> None:
        if not self.in_root:
            return
        self.rel_label_files = []
        self.label_to_classset.clear()
        self.label_to_box_counts.clear()
        self.label_to_image_rel.clear()

        for abs_lf in iter_label_files(self.in_root):
            rel = os.path.normpath(os.path.relpath(abs_lf, self.in_root))
            self.rel_label_files.append(rel)

            classset: Set[int] = set()
            box_counts: Dict[int, int] = {}

            try:
                with open(abs_lf, "r", encoding="utf-8") as f:
                    lines = f.readlines()
            except Exception:
                self.label_to_classset[rel] = set()
                self.label_to_box_counts[rel] = {}
                self.label_to_image_rel[rel] = find_matching_image(self.in_root, rel)
                continue

            for ln in lines:
                parsed = parse_label_line(ln)
                if not parsed:
                    continue
                cid, _, _, _, _ = parsed
                classset.add(cid)
                box_counts[cid] = box_counts.get(cid, 0) + 1

            self.label_to_classset[rel] = classset
            self.label_to_box_counts[rel] = box_counts
            self.label_to_image_rel[rel] = find_matching_image(self.in_root, rel)

        self.rel_label_files.sort()

    def set_output(self, out_root: str) -> None:
        if not self.loaded:
            raise DatasetError("Load input dataset first.")
        self.out_root = os.path.abspath(out_root)

    def ensure_ready(self) -> None:
        if not self.loaded or not self.in_root:
            raise DatasetError("Input dataset not loaded.")
        if not self.out_root:
            raise DatasetError("Output folder not set.")
        if os.path.abspath(self.out_root) == os.path.abspath(self.in_root):
            raise DatasetError("Output folder must be different from input folder.")

    def _resolve_uid(self, uid: int) -> int:
        while uid in self.uid_redirect:
            uid = self.uid_redirect[uid]
        return uid

    def get_classes(self) -> List[Tuple[int, str]]:
        return [(i, self.uid_to_name[uid]) for i, uid in enumerate(self.class_order)]

    def rename_class(self, index: int, new_name: str) -> None:
        if index < 0 or index >= len(self.class_order):
            raise DatasetError("Invalid class index.")
        new_name = new_name.strip()
        if not new_name:
            raise DatasetError("Class name cannot be empty.")
        self.uid_to_name[self.class_order[index]] = new_name

    def move_class(self, from_index: int, to_index: int) -> None:
        n = len(self.class_order)
        if not (0 <= from_index < n and 0 <= to_index < n):
            raise DatasetError("Invalid indices.")
        uid = self.class_order.pop(from_index)
        self.class_order.insert(to_index, uid)

    def delete_classes_by_indices(self, indices: List[int]) -> None:
        if not indices:
            return
        n = len(self.class_order)
        idx_set = set(indices)
        if any(i < 0 or i >= n for i in idx_set):
            raise DatasetError("Invalid class index in deletion.")
        if len(idx_set) >= n:
            raise DatasetError("You cannot delete all classes.")
        self.class_order = [uid for i, uid in enumerate(self.class_order) if i not in idx_set]

        alive = set(self.class_order)
        for src, tgt in list(self.uid_redirect.items()):
            tgt2 = self._resolve_uid(tgt)
            if tgt2 not in alive:
                del self.uid_redirect[src]

    def merge_classes(self, source_indices: List[int], target_index: int) -> None:
        n = len(self.class_order)
        if target_index < 0 or target_index >= n:
            raise DatasetError("Invalid target index.")

        src_set = set(source_indices)
        if target_index in src_set:
            src_set.remove(target_index)
        if not src_set:
            return
        if any(i < 0 or i >= n for i in src_set):
            raise DatasetError("Invalid source index in merge.")

        target_uid = self.class_order[target_index]
        source_uids = [self.class_order[i] for i in sorted(src_set)]

        for suid in source_uids:
            suid_res = self._resolve_uid(suid)
            if suid_res != target_uid:
                self.uid_redirect[suid_res] = target_uid

        remove_set = set(source_uids)
        self.class_order = [uid for uid in self.class_order if uid not in remove_set]

    # ---------- stats ----------
    def compute_stats(self) -> Tuple[Dict[int, int], Dict[int, int], Dict[int, int], int, int, List[str]]:
        if not self.loaded or not self.in_root:
            raise DatasetError("Input not loaded.")

        warnings: List[str] = []
        total_label_files = len(self.rel_label_files)

        uid_to_new_index = {uid: i for i, uid in enumerate(self.class_order)}
        alive_uids = set(self.class_order)

        box_counts_by_uid: Dict[int, int] = {}
        single_images_by_uid: Dict[int, int] = {}
        overlap_images_by_uid: Dict[int, int] = {}
        total_boxes_kept = 0

        for rel in self.rel_label_files:
            classset = self.label_to_classset.get(rel, set())
            box_counts = self.label_to_box_counts.get(rel, {})

            alive_uids_in_image: Set[int] = set()
            for ocid in classset:
                if ocid not in self.original_index_to_uid:
                    warnings.append(f"Unknown class id {ocid} in {rel}.")
                    continue
                ouid = self._resolve_uid(self.original_index_to_uid[ocid])
                if ouid in alive_uids:
                    alive_uids_in_image.add(ouid)

            for ocid, cnt in box_counts.items():
                if ocid not in self.original_index_to_uid:
                    continue
                ouid = self._resolve_uid(self.original_index_to_uid[ocid])
                if ouid not in alive_uids:
                    continue
                box_counts_by_uid[ouid] = box_counts_by_uid.get(ouid, 0) + cnt
                total_boxes_kept += cnt

            if len(alive_uids_in_image) == 1:
                only_uid = next(iter(alive_uids_in_image))
                single_images_by_uid[only_uid] = single_images_by_uid.get(only_uid, 0) + 1
            elif len(alive_uids_in_image) > 1:
                for uid in alive_uids_in_image:
                    overlap_images_by_uid[uid] = overlap_images_by_uid.get(uid, 0) + 1

        box_by_idx: Dict[int, int] = {}
        single_by_idx: Dict[int, int] = {}
        overlap_by_idx: Dict[int, int] = {}

        for uid, cnt in box_counts_by_uid.items():
            idx = uid_to_new_index.get(uid)
            if idx is not None:
                box_by_idx[idx] = cnt
        for uid, cnt in single_images_by_uid.items():
            idx = uid_to_new_index.get(uid)
            if idx is not None:
                single_by_idx[idx] = cnt
        for uid, cnt in overlap_images_by_uid.items():
            idx = uid_to_new_index.get(uid)
            if idx is not None:
                overlap_by_idx[idx] = cnt

        return box_by_idx, single_by_idx, overlap_by_idx, total_boxes_kept, total_label_files, warnings

    def compute_full_image_stats(self) -> Tuple[Dict[int, int], List[List[int]]]:
        """
        Returns:
          any_images_by_new_index: idx -> count of images containing this class
          overlap_matrix: NxN, M[i][j] = #images containing both i and j
        """
        if not self.loaded or not self.in_root:
            raise DatasetError("Input not loaded.")

        n = len(self.class_order)
        uid_to_new_index = {uid: i for i, uid in enumerate(self.class_order)}
        alive_uids = set(self.class_order)

        any_images_by_idx: Dict[int, int] = {i: 0 for i in range(n)}
        matrix = [[0 for _ in range(n)] for _ in range(n)]

        for rel in self.rel_label_files:
            classset = self.label_to_classset.get(rel, set())

            alive_uids_in_image: Set[int] = set()
            for ocid in classset:
                if ocid not in self.original_index_to_uid:
                    continue
                ouid = self._resolve_uid(self.original_index_to_uid[ocid])
                if ouid in alive_uids:
                    alive_uids_in_image.add(ouid)

            if not alive_uids_in_image:
                continue

            idxs = sorted(uid_to_new_index[uid] for uid in alive_uids_in_image)

            for i in idxs:
                any_images_by_idx[i] += 1

            for a in range(len(idxs)):
                for b in range(a + 1, len(idxs)):
                    i, j = idxs[a], idxs[b]
                    matrix[i][j] += 1
                    matrix[j][i] += 1

        return any_images_by_idx, matrix

    # ---------- deletion plan ----------
    def clear_deletion_plan(self) -> None:
        self.delete_rel_labels.clear()
        self.delete_rel_images.clear()
        self.deletion_ops.clear()

    # ---------- apply ----------
    def apply_to_output(self, copy_non_label_files: bool) -> Tuple[int, int, int, int, int, List[str]]:
        self.ensure_ready()
        assert self.in_root and self.out_root

        warnings: List[str] = []
        os.makedirs(self.out_root, exist_ok=True)

        uid_to_new_index = {uid: i for i, uid in enumerate(self.class_order)}
        alive_uids = set(self.class_order)

        write_classes_txt(
            os.path.join(self.out_root, CLASSES_FILENAME),
            [self.uid_to_name[uid] for uid in self.class_order]
        )

        files_copied = 0
        if copy_non_label_files:
            for p in iter_all_files(self.in_root):
                rel = os.path.normpath(os.path.relpath(p, self.in_root))
                rel_lower = rel.replace("\\", "/").lower()

                if rel_lower == CLASSES_FILENAME:
                    continue
                if rel_lower.endswith(".txt") and rel_lower != CLASSES_FILENAME:
                    continue
                if rel in self.delete_rel_images:
                    continue

                dst = os.path.join(self.out_root, rel)
                os.makedirs(os.path.dirname(dst), exist_ok=True)
                try:
                    shutil.copy2(p, dst)
                    files_copied += 1
                except Exception as e:
                    warnings.append(f"Could not copy {rel} ({e})")

        label_files_written = 0
        label_lines_removed = 0
        boxes_written = 0
        samples_skipped = 0

        for rel in self.rel_label_files:
            if rel in self.delete_rel_labels:
                samples_skipped += 1
                continue

            abs_lf = os.path.join(self.in_root, rel)
            out_lf = os.path.join(self.out_root, rel)
            os.makedirs(os.path.dirname(out_lf), exist_ok=True)

            try:
                with open(abs_lf, "r", encoding="utf-8") as f:
                    lines = f.readlines()
            except Exception as e:
                warnings.append(f"Could not read {rel} ({e})")
                continue

            out_lines: List[str] = []
            for ln in lines:
                parsed = parse_label_line(ln)
                if not parsed:
                    continue

                cid, x, y, w, h = parsed
                if cid not in self.original_index_to_uid:
                    warnings.append(f"Unknown class id {cid} in {rel} -> skipped line.")
                    continue

                ouid = self._resolve_uid(self.original_index_to_uid[cid])
                if ouid not in alive_uids:
                    label_lines_removed += 1
                    continue

                new_cid = uid_to_new_index[ouid]
                out_lines.append(format_label_line(new_cid, x, y, w, h))
                boxes_written += 1

            if not out_lines:
                continue

            try:
                with open(out_lf, "w", encoding="utf-8") as f:
                    for l in out_lines:
                        f.write(l + "\n")
                label_files_written += 1
            except Exception as e:
                warnings.append(f"Could not write {rel} ({e})")

        return label_files_written, label_lines_removed, boxes_written, files_copied, samples_skipped, warnings



# --- PDF Export ---
def export_stats_pdf(model: 'YoloDatasetModel', pdf_path: str) -> None:
    box_by_idx, single_by_idx, overlap_by_idx, total_boxes, total_files, warnings = model.compute_stats()
    any_by_idx, overlap_matrix = model.compute_full_image_stats()
    classes = model.get_classes()
    n = len(classes)

    styles = getSampleStyleSheet()
    doc = SimpleDocTemplate(pdf_path, pagesize=A4)

    story = []
    story.append(Paragraph("YOLO Dataset – Full Statistics Report", styles["Title"]))
    story.append(Spacer(1, 10))

    story.append(Paragraph(f"<b>Input folder:</b> {model.in_root}", styles["Normal"]))
    story.append(Paragraph(f"<b>Output folder:</b> {model.out_root}", styles["Normal"]))
    story.append(Spacer(1, 8))

    story.append(Paragraph(f"<b>Total label files:</b> {total_files}", styles["Normal"]))
    story.append(Paragraph(f"<b>Total boxes kept:</b> {total_boxes}", styles["Normal"]))
    story.append(Spacer(1, 12))

    data = [["Index", "Class", "Boxes", "Any images", "Single images", "Overlap images"]]
    for idx, name in classes:
        data.append([
            str(idx),
            name,
            str(box_by_idx.get(idx, 0)),
            str(any_by_idx.get(idx, 0)),
            str(single_by_idx.get(idx, 0)),
            str(overlap_by_idx.get(idx, 0)),
        ])

    table = Table(data)
    table.setStyle(TableStyle([
        ("BACKGROUND", (0, 0), (-1, 0), colors.lightgrey),
        ("GRID", (0, 0), (-1, -1), 0.5, colors.grey),
    ]))

    story.append(table)
    doc.build(story)


class ManageSamplesDialog(QDialog):
    """
    Sub-screen to manage deletion planning for one class:
    - choose mode (single / overlap-any / overlap-specific / any)
    - choose N to delete
    - labels only or labels+images
    - preview candidates
    - add to deletion plan
    """
    def __init__(self, parent, model: YoloDatasetModel, class_index: int):
        super().__init__(parent)
        self.model = model
        self.class_index = class_index

        self.setWindowTitle("Manage samples for class")
        self.resize(720, 520)

        main = QVBoxLayout(self)

        self.lbl_title = QLabel("")
        main.addWidget(self.lbl_title)

        self.stats_box = QLabel("")
        main.addWidget(self.stats_box)

        self.lbl_overlap_info = QLabel("")
        main.addWidget(self.lbl_overlap_info)

        self.lbl_candidates = QLabel("")
        main.addWidget(self.lbl_candidates)

        modes_group = QGroupBox("Deletion target")
        modes_layout = QVBoxLayout(modes_group)

        self.rb_single = QRadioButton("Single-class images (only this class)")
        self.rb_overlap_any = QRadioButton("Overlap images (this class + any other)")
        self.rb_overlap_specific = QRadioButton("Overlap with specific class (this + selected)")
        self.rb_any = QRadioButton("Any image containing this class")
        self.rb_single.setChecked(True)

        self.mode_buttons = QButtonGroup(self)
        for rb in [self.rb_single, self.rb_overlap_any, self.rb_overlap_specific, self.rb_any]:
            self.mode_buttons.addButton(rb)

        modes_layout.addWidget(self.rb_single)
        modes_layout.addWidget(self.rb_overlap_any)
        modes_layout.addWidget(self.rb_overlap_specific)

        overlap_row = QHBoxLayout()
        overlap_row.addWidget(QLabel("Overlap-with class:"))
        self.cmb_overlap = QComboBox()
        overlap_row.addWidget(self.cmb_overlap, 1)
        modes_layout.addLayout(overlap_row)

        modes_layout.addWidget(self.rb_any)
        main.addWidget(modes_group)

        params_group = QGroupBox("Parameters")
        form = QFormLayout(params_group)

        self.spin_n = QSpinBox()
        self.spin_n.setRange(1, 1_000_000)
        self.spin_n.setValue(100)
        form.addRow("How many images to delete:", self.spin_n)

        self.cmb_delete_kind = QComboBox()
        self.cmb_delete_kind.addItems([
            "Delete labels only (keep images)",
            "Delete labels + images (remove sample completely)"
        ])
        form.addRow("Deletion type:", self.cmb_delete_kind)

        self.btn_preview = QPushButton("Preview candidates")
        self.btn_preview.clicked.connect(self.on_preview)
        form.addRow(self.btn_preview)

        main.addWidget(params_group)

        self.preview = QTextEdit()
        self.preview.setReadOnly(True)
        main.addWidget(self.preview, 1)

        bb = QDialogButtonBox()
        self.btn_add = bb.addButton("Add to deletion plan", QDialogButtonBox.AcceptRole)
        self.btn_close = bb.addButton("Close", QDialogButtonBox.RejectRole)
        self.btn_add.clicked.connect(self.on_add_plan)
        self.btn_close.clicked.connect(self.reject)
        main.addWidget(bb)

        self._populate_overlap_classes()
        self._refresh_header()
        self.on_preview()
        self._refresh_overlap_info()

        self.rb_single.toggled.connect(self._refresh_overlap_info)
        self.rb_overlap_any.toggled.connect(self._refresh_overlap_info)
        self.rb_overlap_specific.toggled.connect(self._refresh_overlap_info)
        self.rb_any.toggled.connect(self._refresh_overlap_info)
        self.cmb_overlap.currentIndexChanged.connect(self._refresh_overlap_info)

        self.rb_overlap_specific.toggled.connect(self._update_overlap_enabled)
        self._update_overlap_enabled()
    def _refresh_overlap_info(self):
        # Always show "how many images contain this class"
        any_by_idx, overlap_matrix = self.model.compute_full_image_stats()
        base_any = any_by_idx.get(self.class_index, 0)

        # If overlap-specific is selected, show pairwise overlap too
        if self.rb_overlap_specific.isChecked() and self.cmb_overlap.currentIndex() >= 0:
            other_idx = int(self.cmb_overlap.currentData())
            pair = overlap_matrix[self.class_index][other_idx]
            self.lbl_overlap_info.setText(
                f"Any images with this class: {base_any} | "
                f"Overlap with selected class: {pair}"
            )
        else:
            self.lbl_overlap_info.setText(f"Any images with this class: {base_any}")

        # Also show how many candidates match the CURRENT mode
        self.lbl_candidates.setText(f"Candidates for current filter: {len(self._compute_candidates())}")

    def _update_overlap_enabled(self):
        self.cmb_overlap.setEnabled(self.rb_overlap_specific.isChecked())

    def _populate_overlap_classes(self):
        self.cmb_overlap.clear()
        for idx, name in self.model.get_classes():
            if idx == self.class_index:
                continue
            self.cmb_overlap.addItem(f"{idx}: {name}", idx)

    def _refresh_header(self):
        name = self.model.get_classes()[self.class_index][1]
        self.lbl_title.setText(f"Class {self.class_index}: {name}")

        box_by_idx, single_by_idx, overlap_by_idx, _, _, _ = self.model.compute_stats()
        boxes = box_by_idx.get(self.class_index, 0)
        singles = single_by_idx.get(self.class_index, 0)
        overlaps = overlap_by_idx.get(self.class_index, 0)
        self.stats_box.setText(f"Stats: Boxes={boxes} | Single-images={singles} | Overlap-images={overlaps}")

    def _compute_candidates(self) -> List[str]:
        target_uid = self.model.class_order[self.class_index]
        alive_uids = set(self.model.class_order)

        require_uid = None
        if self.rb_overlap_specific.isChecked() and self.cmb_overlap.currentIndex() >= 0:
            require_idx = int(self.cmb_overlap.currentData())
            require_uid = self.model.class_order[require_idx]

        candidates: List[str] = []
        for rel in self.model.rel_label_files:
            classset = self.model.label_to_classset.get(rel, set())

            alive_uids_in_image: Set[int] = set()
            for ocid in classset:
                if ocid not in self.model.original_index_to_uid:
                    continue
                ouid = self.model._resolve_uid(self.model.original_index_to_uid[ocid])
                if ouid in alive_uids:
                    alive_uids_in_image.add(ouid)

            if target_uid not in alive_uids_in_image:
                continue

            if self.rb_single.isChecked():
                if len(alive_uids_in_image) == 1:
                    candidates.append(rel)
            elif self.rb_overlap_any.isChecked():
                if len(alive_uids_in_image) > 1:
                    candidates.append(rel)
            elif self.rb_overlap_specific.isChecked():
                if require_uid is None:
                    continue
                if len(alive_uids_in_image) > 1 and require_uid in alive_uids_in_image:
                    candidates.append(rel)
            elif self.rb_any.isChecked():
                candidates.append(rel)

        candidates.sort()
        candidates = [c for c in candidates if c not in self.model.delete_rel_labels]
        return candidates

    def on_preview(self):
        candidates = self._compute_candidates()
        n = self.spin_n.value()
        take = candidates[:n]

        mode_txt = "single" if self.rb_single.isChecked() else \
                   "overlap-any" if self.rb_overlap_any.isChecked() else \
                   "overlap-specific" if self.rb_overlap_specific.isChecked() else "any"

        self.preview.setPlainText(
            f"Mode: {mode_txt}\n"
            f"Available candidates: {len(candidates)}\n"
            f"Will add to plan: {min(n, len(candidates))}\n\n"
            f"First {min(30, len(take))} files:\n" +
            "\n".join(take[:30])
        )
        self._refresh_overlap_info()

    def on_add_plan(self):
        candidates = self._compute_candidates()
        n = self.spin_n.value()
        take = candidates[:n]
        if not take:
            QMessageBox.information(self, "Nothing to add", "No candidates match the selected filter.")
            return

        mode_txt = "single" if self.rb_single.isChecked() else \
                   "overlap-any" if self.rb_overlap_any.isChecked() else \
                   "overlap-specific" if self.rb_overlap_specific.isChecked() else "any"

        overlap_idx = None
        if mode_txt == "overlap-specific" and self.cmb_overlap.currentIndex() >= 0:
            overlap_idx = int(self.cmb_overlap.currentData())

        op = DeletionOp(
            class_index=self.class_index,
            mode=mode_txt,
            n=self.spin_n.value(),
            delete_images_too=(self.cmb_delete_kind.currentIndex() == 1),
            overlap_with_index=overlap_idx
        )
        self.model.deletion_ops.append(op)
        self.model.rebuild_deletion_sets_from_ops()

        QMessageBox.information(
            self, "Added",
            f"Plan now contains: {len(self.model.delete_rel_labels)} labels, {len(self.model.delete_rel_images)} images"
        )
        self.on_preview()



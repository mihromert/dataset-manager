            QMessageBox.warning(self, "PDF", "Load an input dataset first.")
            return

        default_name = "yolo_full_stats_report.pdf"
        start_dir = self.model.out_root if self.model.out_root else self.model.in_root

        pdf_path, _ = QFileDialog.getSaveFileName(
            self,

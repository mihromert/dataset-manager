            return

        try:
            export_stats_pdf(self.model, pdf_path)
            QMessageBox.information(self, "PDF", f"PDF saved:\n{pdf_path}")
        except Exception as e:
            QMessageBox.critical(self, "PDF Error", str(e))

    # ----- class actions -----
    def on_rename(self):
        idxs = self.selected_indices()
        if len(idxs) != 1:
            QMessageBox.warning(self, "Rename", "Select exactly ONE class to rename.")
            return
        i = idxs[0]
        old = self.model.get_classes()[i][1]
        new, ok = QInputDialog.getText(self, "Rename Class", f"New name for index {i}:", text=old)
        if not ok:
            return
        try:
            self.model.rename_class(i, new)
            self.refresh_class_list()
            self.refresh_stats()
        except Exception as e:
            QMessageBox.critical(self, "Error", str(e))

    def on_up(self):
        idxs = self.selected_indices()
        if len(idxs) != 1:
            QMessageBox.warning(self, "Move", "Select exactly ONE class to move.")
            return
        i = idxs[0]
        if i == 0:
            return
        try:
            self.model.move_class(i, i - 1)
            self.refresh_class_list()
            self.class_list.setCurrentRow(i - 1)
            self.refresh_stats()
        except Exception as e:
            QMessageBox.critical(self, "Error", str(e))

    def on_down(self):
        idxs = self.selected_indices()
        if len(idxs) != 1:
            QMessageBox.warning(self, "Move", "Select exactly ONE class to move.")
            return
        i = idxs[0]
        if i >= self.class_list.count() - 1:
            return
        try:
            self.model.move_class(i, i + 1)
            self.refresh_class_list()
            self.class_list.setCurrentRow(i + 1)
            self.refresh_stats()
        except Exception as e:
            QMessageBox.critical(self, "Error", str(e))

    def on_merge(self):
        idxs = self.selected_indices()
        if len(idxs) < 2:
            QMessageBox.warning(self, "Merge", "Select TWO OR MORE classes to merge.")
            return
        target = idxs[0]
        sources = idxs[1:]
        try:
            self.model.merge_classes(sources, target)
            self.refresh_class_list()
            self.refresh_stats()
        except Exception as e:
            QMessageBox.critical(self, "Error", str(e))

    def on_delete_classes(self):
        idxs = self.selected_indices()
        if not idxs:
            return
        reply = QMessageBox.question(
            self, "Delete Classes",
            f"Delete {len(idxs)} class(es)?\n\n"
            "They will be removed from OUTPUT/classes.txt and their annotations will be removed from OUTPUT labels."
        )
        if reply != QMessageBox.Yes:
            return
        try:
            self.model.delete_classes_by_indices(idxs)
            self.refresh_class_list()
            self.refresh_stats()
        except Exception as e:
            QMessageBox.critical(self, "Error", str(e))

    def on_class_context_menu(self, pos: QPoint):
        item = self.class_list.itemAt(pos)
        if item is None:
            menu = QMenu(self)
            act_clear = menu.addAction("Clear deletion plan")
            chosen = menu.exec(self.class_list.mapToGlobal(pos))
            if chosen == act_clear:
                self.model.clear_deletion_plan()
                self.refresh_stats()
            return

        row = self.class_list.row(item)
        class_name = self.model.get_classes()[row][1]

        menu = QMenu(self)
        menu.addSection(f"Class {row}: {class_name}")

        act_manage = menu.addAction("Manage samples... (sub-screen)")
        menu.addSeparator()
        act_clear = menu.addAction("Clear deletion plan")

        chosen = menu.exec(self.class_list.mapToGlobal(pos))
        if chosen is None:
            return

        if chosen == act_clear:
            self.model.clear_deletion_plan()
            self.refresh_stats()
            return

        if chosen == act_manage:
            dlg = ManageSamplesDialog(self, self.model, row)
            dlg.exec()
            self.refresh_stats()
            return

    def on_apply(self):
        try:
            self.model.ensure_ready()
        except Exception as e:
            QMessageBox.critical(self, "Error", str(e))
            return

        reply = QMessageBox.question(
            self, "Apply",
            "This will WRITE a new dataset into OUTPUT folder.\n\n"
            "INPUT will NOT be changed.\n\nContinue?"
        )
        if reply != QMessageBox.Yes:
            return

        try:
            lf_written, removed, boxes_written, files_copied, samples_skipped, warnings = self.model.apply_to_output(
                copy_non_label_files=self.chk_copy.isChecked()
            )
            msg = (
                "Output dataset created.\n\n"
                f"Label files written: {lf_written}\n"
                f"Label files skipped (deletion plan): {samples_skipped}\n"
                f"Annotation lines removed (deleted classes): {removed}\n"
                f"Boxes written: {boxes_written}\n"
                f"Non-label files copied: {files_copied}\n"
            )
            if warnings:
                msg += f"\nWarnings: {len(warnings)}\n"
            QMessageBox.information(self, "Done", msg)
            self.refresh_stats()
        except Exception as e:
            QMessageBox.critical(self, "Error", str(e))


